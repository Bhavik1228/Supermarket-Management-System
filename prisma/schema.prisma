generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User & Role Management
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  phone         String?   @unique

  role String @default("STORE_OWNER") // SYSTEM_OWNER, STORE_OWNER, STORE_MANAGER, STORE_STAFF, CUSTOMER

  // Referral System
  referralCode String? @unique // Unique code for this user to share
  referredBy   String? // User ID of referrer
  referredAt   DateTime? // When they were referred

  // Relations
  stores      Store[] @relation("StoreOwner")
  workingAt   Store?  @relation("StoreStaff", fields: [workingAtId], references: [id])
  workingAtId String?

  tickets Ticket[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  LoyaltyAccount LoyaltyAccount[]
  orders         Order[]
  
  // Coupon Relations
  assignedCoupons Coupon[] @relation("AssignedCoupons")
  giftedCoupons   Coupon[] @relation("GiftedCoupons")
  couponUsages    CouponUsage[]
  
  // Gamification Relations
  gameParticipations GameParticipation[]
}

model Store {
  id        String @id @default(cuid())
  name      String
  storeType String @default("SUPERMARKET") // SUPERMARKET, GROCERY, RETAIL, PHARMACY, ELECTRONICS, RESTAURANT
  status    String @default("PENDING") // PENDING, APPROVED, REJECTED, SUSPENDED

  // Owner Relation
  ownerId String
  owner   User   @relation("StoreOwner", fields: [ownerId], references: [id])

  // Staff Relation
  staff User[] @relation("StoreStaff")

  // Data
  products Product[]
  tickets  Ticket[]
  orders   Order[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  LoyaltyProgram LoyaltyProgram[]
  coupons        Coupon[]
  purchaseOrders PurchaseOrder[]

  // Accounting Relations
  accounts       Account[]
  journalEntries JournalEntry[]
  taxSlabs       TaxSlab[]
  fiscalPeriods  FiscalPeriod[]
  suppliers      Supplier[]
  adCampaigns    AdCampaign[]
}

model Product {
  id      String  @id @default(cuid())
  name    String
  price   Float
  stock   Int     @default(0)
  barcode String? @unique
  category String @default("General") // For loyalty rules: Beverages, Fresh Produce, Dairy, etc.
  reorderPoint Int @default(10)
  reorderQuantity Int @default(50)
  costPrice Float? @default(0)
  
  batches ProductBatch[]

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Support System
model Ticket {
  id       String @id @default(cuid())
  subject  String
  status   String @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority String @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT

  // Creator
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Context (Optional)
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  messages TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketMessage {
  id       String @id @default(cuid())
  message  String
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  isStaff Boolean @default(false) // True if sent by admin/support

  createdAt DateTime @default(now())
}

// Audit & Logging
model AuditLog {
  id       String  @id @default(cuid())
  action   String
  entity   String // E.g., "Store", "User", "Product"
  entityId String?
  details  String? // JSON string or description
  storeId  String? // Added to filter logs by store (null for system-wide logs)

  userId    String? // Who performed the action
  userEmail String? // Snapshot of user email
  ipAddress String?

  createdAt DateTime @default(now())
}

// Sales & Transactions
model Order {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  total    Float
  subtotal Float
  tax      Float
  discount Float @default(0)

  status        String @default("COMPLETED") // COMPLETED, REFUNDED, CANCELLED, PENDING, CONFIRMED, PREPARING, READY, OUT_FOR_DELIVERY, DELIVERED
  paymentMethod String // CASH, CARD, MOBILE_MONEY
  paymentReference String? // For online transactions
  channel       String @default("IN_STORE") // IN_STORE, ONLINE, APP, POS
  fulfillmentMethod String @default("INSTANT") // INSTANT, PICKUP, DELIVERY
  
  // Delivery/Shipping Info
  customerAddress String?
  customerPhone   String?
  customerEmail   String?
  notes           String?

  items        OrderItem[]
  transactions Transaction[]

  customerId String?
  customer   User?   @relation(fields: [customerId], references: [id])

  cashierId   String?
  cashierName String? // Snapshot of name

  couponUsages CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float // Price at the time of sale
  name     String // Snapshot of product name

  total Float // quantity * price

  @@index([orderId])
  @@index([productId])
}

model PurchaseOrder {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  status  String @default("PENDING") // PENDING, SENT, RECEIVED, CANCELLED
  total   Float  @default(0)

  items   PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String  @id @default(cuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  category  String? // Meat, Dairy, Vegetables, etc.
  
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id])

  products       Product[]
  purchaseOrders PurchaseOrder[]

  reliability Float @default(1.0) // 0 to 1
  payables    Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderItem {
  id      String @id @default(cuid())
  poId    String
  po      PurchaseOrder @relation(fields: [poId], references: [id])

  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  total       Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  type   String // PAYMENT, REFUND
  amount Float
  status String @default("SUCCESS")

  createdAt DateTime @default(now())
}

// Loyalty System
model LoyaltyProgram {
  id          String           @id @default(cuid())
  name        String
  description String?
  storeId     String? // If null, global program
  store       Store?           @relation(fields: [storeId], references: [id])
  tiers       LoyaltyTier[]
  rules       LoyaltyRule[]
  accounts    LoyaltyAccount[]

  status String @default("ACTIVE") // ACTIVE, INACTIVE
  programType String @default("POINTS") // POINTS, SPEND, VISIT, TIERED, CASHBACK, COUPON, MEMBERSHIP, EVENT, REFERRAL, GAMIFIED
  
  currencyName String @default("Points")
  earningRate  Float  @default(1.0)
  isActive     Boolean @default(true)
  
  // Expiry & Redemption Settings
  pointExpiryDays Int? // Points expire after X days (null = never expire)
  redemptionCoolingDays Int? // Min days between redemptions (null = no restriction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coupons Coupon[]
}

model LoyaltyRule {
  id        String         @id @default(cuid())
  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id])

  type       String // SPEND, VISIT, PRODUCT, CATEGORY, SIGNUP, REFERRAL
  targetId   String? // Product ID or Category ID if applicable
  multiplier Float   @default(1.0)
  points     Int     @default(0) // Fixed points for non-spend rules
  minSpend   Float?

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyTier {
  id         String           @id @default(cuid())
  name       String // Bronze, Silver, Gold
  minPoints  Int // Points needed to reach this tier
  multiplier Float            @default(1.0) // Earning multiplier
  programId  String
  program    LoyaltyProgram   @relation(fields: [programId], references: [id])
  accounts   LoyaltyAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyAccount {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id])

  pointsBalance  Int          @default(0)
  lifetimePoints Int          @default(0)
  tierId         String?
  tier           LoyaltyTier? @relation(fields: [tierId], references: [id])

  transactions LoyaltyTransaction[]
  cards        LoyaltyCard[]
  coupons      Coupon[]
  
  lastRedemptionAt DateTime? // Track last redemption for cooling period

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, programId])
}

model LoyaltyTransaction {
  id        String         @id @default(cuid())
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id])

  type        String // EARN, REDEEM, EXPIRE, ADJUST, BONUS
  points      Int // Positive for earn, negative for redeem
  referenceId String? // Order ID, etc.
  description String?
  
  expiresAt DateTime? // When these points expire (for EARN transactions)

  createdAt DateTime @default(now())
}

model LoyaltyCard {
  id        String         @id @default(cuid())
  code      String         @unique // Barcode/QR content
  type      String // PHYSICAL, DIGITAL
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id])
  isActive  Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id        String          @id @default(cuid())
  code      String          @unique
  
  accountId String?
  account   LoyaltyAccount? @relation(fields: [accountId], references: [id])

  storeId   String?
  store     Store?          @relation(fields: [storeId], references: [id])

  title       String? // Made optional to support 'coupons.ts' usage of 'description' primarily
  description String?

  discountType String // PERCENTAGE, FIXED_AMOUNT, ITEM_FREE, FREE_SHIPPING
  value        Float  // discountValue

  minSpend    Float? // minPurchase
  maxDiscount Float?

  status    String    @default("ACTIVE") // ACTIVE, REDEEMED, EXPIRED, DISABLED
  isActive  Boolean   @default(true)
  expiresAt DateTime? // expiryDate
  startDate DateTime?

  // Usage tracking
  usageType      String  @default("SINGLE") // SINGLE, MULTI, UNLIMITED
  maxUses        Int?
  maxUsesPerUser Int?    @default(1)
  usesCount      Int     @default(0)

  // Advanced features
  isPersonalized Boolean @default(false)
  isStackable     Boolean @default(false)
  pointsCost     Int?
  
  // Assignment & Gifting
  assignedToId String?
  assignedTo   User?   @relation("AssignedCoupons", fields: [assignedToId], references: [id])
  giftedById   String?
  giftedBy     User?   @relation("GiftedCoupons", fields: [giftedById], references: [id])
  giftMessage  String?

  usage CouponUsage[]
  
  loyaltyProgramId String?
  loyaltyProgram   LoyaltyProgram? @relation(fields: [loyaltyProgramId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CouponUsage {
  id        String @id @default(cuid())
  couponId  String
  coupon    Coupon @relation(fields: [couponId], references: [id])
  
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  
  orderId   String?
  order     Order? @relation(fields: [orderId], references: [id])
  
  discountAmount Float
  usedAt         DateTime @default(now())
}

// Gamification Models
model GamifiedGame {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  
  cooldownHours Int    @default(24) // How often they can play
  
  rewards        GamifiedReward[]
  participation  GameParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GamifiedReward {
  id        String       @id @default(cuid())
  gameId    String
  game      GamifiedGame @relation(fields: [gameId], references: [id])
  
  name      String
  type      String // POINTS, COUPON, BETTER_LUCK
  value     Float // Points or Coupon Discount Value
  couponId  String? // Optional linked coupon
  
  chance    Float // Probability (e.g. 0.1 for 10%)
  
  wonBy GameParticipation[]

  createdAt DateTime @default(now())
}

model GameParticipation {
  id        String   @id @default(cuid())
  gameId    String
  game      GamifiedGame @relation(fields: [gameId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  rewardId  String?
  reward    GamifiedReward? @relation(fields: [rewardId], references: [id])
  
  wonAt     DateTime @default(now())
}

// Ads & Marketing
model AdCampaign {
  id          String   @id @default(cuid())
  name        String
  client      String // Brand/Company Name
  placement   String // DASHBOARD_TOP, SIDEBAR, CHECKOUT
  
  status      String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED
  
  impressions Int      @default(0)
  clicks      Int      @default(0)
  
  revenue     Float    @default(0)
  
  startDate   DateTime?
  endDate     DateTime?

  storeId     String? // Optional for now to avoid breaking existing data
  store       Store?   @relation(fields: [storeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Config & Automation
model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON string
  
  description String?
  updatedAt   DateTime @updatedAt
}

model AutomationRule {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)
  
  triggerType String // SCHEDULE, EVENT
  actionType  String // NOTIFY, SUSPEND, APPROVE
  conditions  String // JSON Logic
  
  lastRun     DateTime?
  runCount    Int @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Accounting Module

model Account {
  id          String         @id @default(cuid())
  storeId     String
  store       Store          @relation(fields: [storeId], references: [id])
  code        String
  name        String
  type        String         // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  balance     Float          @default(0)
  entries     JournalLine[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([storeId, code])
}

model JournalEntry {
  id          String        @id @default(cuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  date        DateTime      @default(now())
  description String
  referenceId String?       
  lines       JournalLine[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model JournalLine {
  id          String       @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id])
  accountId   String
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Float        @default(0)
  credit      Float        @default(0)
}

model TaxSlab {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  name        String   // e.g. "VAT 18%"
  rate        Float    // 0.18
  type        String   // PERCENTAGE, FIXED

  isActive    Boolean  @default(true)
}

model FiscalPeriod {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String   // "Jan 2026"
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  
  closedAt  DateTime?
}

// Documents System (Invoices, Quotations, Credit Notes)
model Document {
  id              String   @id @default(cuid())
  storeId         String
  type            String   // INVOICE, QUOTATION, CREDIT_NOTE, DELIVERY_NOTE, PURCHASE_ORDER
  number          String   @unique // INV-2401-0001, QUO-2401-0001
  
  // Customer Info (snapshot)
  customerId      String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerAddress String?
  
  // Related Order (for invoices from POS)
  orderId         String?
  
  // Financials
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  discount        Float    @default(0)
  total           Float    @default(0)
  
  // Status
  status          String   @default("DRAFT") // DRAFT, SENT, PAID, CANCELLED, ACCEPTED, REJECTED, ISSUED
  
  // Line Items (JSON string for SQLite compatibility)
  items           String   // JSON array of { name, quantity, price, tax, total }
  
  // Metadata (JSON string for SQLite compatibility)
  metadata        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([storeId])
  @@index([type])
  @@index([status])
}

model ProductBatch {
  id            String    @id @default(cuid())
  batchNumber   String
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  
  quantity      Int
  initialQuantity Int
  
  expiryDate    DateTime
  arrivalDate   DateTime  @default(now())
  
  status        String    @default("ACTIVE") // ACTIVE, EXPIRED, DISCARDED
  
  costPrice     Float?    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([expiryDate])
}
